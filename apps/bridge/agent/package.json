{
  "name": "eins-agent",
  "version": "0.1.0",
  "description": "EINS PVS Bridge — GDT-Agent for on-prem Praxis-Software (Windows + macOS)",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "eins-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:bin": "tsc -p tsconfig.json && pkg dist/index.js --targets node20-win-x64,node20-macos-x64 --output bin/eins-agent",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.3",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
