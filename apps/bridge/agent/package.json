{
  "name": "eins-agent",
  "version": "0.2.0",
  "description": "EINS PVS Bridge: on-prem agent for Praxis-Software (GDT, CSV, SQL-introspection) on Windows + macOS",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "eins-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "prebuild": "node ../scripts/gen-canonical.mjs",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "build:bundle": "tsc -p tsconfig.json && node scripts/copy-assets.mjs && node scripts/bundle.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "better-sqlite3-multiple-ciphers": "^12.10.0",
    "chokidar": "^4.0.3",
    "iconv-lite": "^0.6.3",
    "mssql": "^11.0.1",
    "mysql2": "^3.11.5",
    "node-firebird": "^1.1.9",
    "oracledb": "^6.6.0",
    "pg": "^8.13.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.9.0",
    "@types/oracledb": "^6.10.0",
    "@types/pg": "^8.11.10",
    "pg-mem": "^3.0.4",
    "testcontainers": "^12.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
