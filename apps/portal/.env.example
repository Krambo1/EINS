# ============================================================
# EINS PORTAL — environment variables
# Copy to .env.local for your own dev setup; never commit secrets.
# Every variable is declared once in src/lib/env.ts (validated via t3-env/zod).
# ============================================================

# --- Runtime --------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_ORIGIN=http://localhost:3001
# Origin for admin-host URLs (admin magic-links / password reset). Optional —
# if unset, derived from APP_ORIGIN by prepending `admin.` to the host.
# Override in prod if the admin panel lives on a fully separate domain.
# ADMIN_ORIGIN=http://admin.localhost:3001

# --- Database (Docker Compose defaults) -----------------------
DATABASE_URL=postgres://eins:eins_dev_password@localhost:5432/eins_portal
# Application role (RLS enforced). Swap to this in production.
DATABASE_URL_APP=postgres://eins_app:eins_app_dev@localhost:5432/eins_portal

# --- Background jobs / queue (pg-boss on Postgres) -----------
# The portal job system runs on pg-boss (Postgres) — no Redis. The always-on
# worker (`pnpm worker`) needs a DIRECT / session-mode Postgres URL: pg-boss
# holds long-lived workers and takes advisory locks for maintenance, which a
# transaction-mode pooler (Neon `-pooler` / PgBouncer) breaks. Falls back to
# DATABASE_URL when unset (fine for local Docker, which has no pooler). In prod
# set this to Neon's non-pooler endpoint.
# DATABASE_URL_DIRECT=postgres://eins:eins_dev_password@localhost:5432/eins_portal

# --- Session / Crypto ----------------------------------------
# 32-byte hex string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_32_bytes_hex_in_dev
# 32-byte hex for pgcrypto AES wrapping of OAuth tokens.
ENCRYPTION_KEY=change_me_to_another_32_bytes_hex

# --- Email (Resend) ------------------------------------------
# Leave empty in dev → magic-links are logged to the console.
RESEND_API_KEY=
EMAIL_FROM="EINS <team@eins.ag>"
# For local SMTP inspection via Mailhog (set to 'mailhog' to route to Mailhog :1025)
EMAIL_DRIVER=console
# Public URL for the EINS wordmark in transactional emails. Defaults to
# ${APP_ORIGIN}/eins-logo.png; localhost will not load in Gmail/Apple Mail.
# In dev set this to a publicly reachable URL so the logo renders.
EMAIL_LOGO_URL=https://eins.ag/eins-logo.png

# --- Storage (Cloudflare R2) ---------------------------------
# Leave empty in dev → assets are stored under ./storage/.
STORAGE_DRIVER=local
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_BASE=

# --- OpenAI (lead scoring) -----------------------------------
# Leave empty in dev → rule-based fallback scorer is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROMPT_VERSION=v1

# --- Meta Marketing API --------------------------------------
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/integrations/meta/callback
META_API_VERSION=v21.0

# --- Google Ads API ------------------------------------------
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
# MCC (manager) login customer id — set when EINS account is linked.
# Also used as fallback for the oci-purchase worker if a praxis hasn't
# overridden it via clinics.google_ads_login_customer_id.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Closed-loop ads conversion (Meta CAPI Purchase events) --
# Per-praxis CAPI System User token. The slug is the praxis's
# clinics.slug, uppercased, dashes → underscores. So
# `praxis-mueller-muenchen` reads from META_CAPI_TOKEN_PRAXIS_MUELLER_MUENCHEN.
# Same convention as the clinic-landing /api/lead path — if Lead events
# are firing there, Purchase events on InvoicePaid fire too.
# (No global default; absent token = praxis skipped for Meta channel.)
# META_CAPI_TOKEN_PRAXIS_MUELLER_MUENCHEN=
#
# Per-praxis pixel id, Google Ads customer id, and conversion-action
# resource name are stored in the database (clinics.meta_pixel_id,
# .google_ads_customer_id, .google_ads_conversion_action) — set them via
# /einstellungen/integrationen/ads-conversion in the portal UI.

# --- Review syncs (read-only public APIs) ---------------------
# Google Places API (New) — server-side key. Console → Enable "Places API (New)".
# Each clinic stores their place_id under clinic.google_place_id.
GOOGLE_PLACES_API_KEY=

# --- Sentry (EU) ---------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Admin bootstrap -----------------------------------------
# Emails that can log in to /admin. Comma-separated.
ADMIN_EMAILS=team@eins.ag
# Optional IP allowlist for /admin. Empty = no IP restriction (dev default).
ADMIN_IP_ALLOWLIST=

# --- Feature flags -------------------------------------------
# Comma-separated. Each enabling dormant functionality that needs ops work.
FEATURES=
