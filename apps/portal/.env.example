# ============================================================
# EINS PORTAL — environment variables
# Copy to .env.local for your own dev setup; never commit secrets.
# Every variable is declared once in src/lib/env.ts (validated via t3-env/zod).
# ============================================================

# --- Runtime --------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3001
APP_ORIGIN=http://localhost:3001

# --- Database (Docker Compose defaults) -----------------------
DATABASE_URL=postgres://eins:eins_dev_password@localhost:5432/eins_portal
# Application role (RLS enforced). Swap to this in production.
DATABASE_URL_APP=postgres://eins_app:eins_app_dev@localhost:5432/eins_portal

# --- Redis / BullMQ ------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Session / Crypto ----------------------------------------
# 32-byte hex string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_32_bytes_hex_in_dev
# 32-byte hex for pgcrypto AES wrapping of OAuth tokens.
ENCRYPTION_KEY=change_me_to_another_32_bytes_hex

# --- Email (Resend) ------------------------------------------
# Leave empty in dev → magic-links are logged to the console.
RESEND_API_KEY=
EMAIL_FROM="EINS Visuals <portal@einsvisuals.com>"
# For local SMTP inspection via Mailhog (set to 'mailhog' to route to Mailhog :1025)
EMAIL_DRIVER=console

# --- Storage (Cloudflare R2) ---------------------------------
# Leave empty in dev → assets are stored under ./storage/.
STORAGE_DRIVER=local
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_BASE=

# --- OpenAI (lead scoring) -----------------------------------
# Leave empty in dev → rule-based fallback scorer is used.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROMPT_VERSION=v1

# --- Meta Marketing API --------------------------------------
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3001/api/integrations/meta/callback
META_API_VERSION=v21.0

# --- Google Ads API ------------------------------------------
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
# MCC (manager) login customer id — set when EINS account is linked.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Sentry (EU) ---------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Admin bootstrap -----------------------------------------
# Emails that can log in to /admin. Comma-separated.
ADMIN_EMAILS=karam@einsvisuals.com
# Optional IP allowlist for /admin. Empty = no IP restriction (dev default).
ADMIN_IP_ALLOWLIST=

# --- Feature flags -------------------------------------------
# Comma-separated. Each enabling dormant functionality that needs ops work.
FEATURES=
