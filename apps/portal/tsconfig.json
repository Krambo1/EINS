{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@eins/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@eins/ui/*": [
        "../../packages/ui/src/*"
      ]
    }
  },
  "include": [
    ".next-3005/types/**/*.ts",
    ".next-3006/types/**/*.ts",
    ".next-prod/types/**/*.ts",
    ".next/types/**/*.ts",
    "drizzle.config.ts",
    "next-env.d.ts",
    "playwright.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
