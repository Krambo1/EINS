# Per-clinic CRM adapter selector. One of: hubspot | ghl | raw
LEAD_CRM_ADAPTER=raw

# Per-clinic webhook URLs (suffix is the clinic slug, uppercase, dashes -> underscores)
# Example for slug "praxis-mueller-muenchen":
# LEAD_WEBHOOK_URL_PRAXIS_MUELLER_MUENCHEN=https://hooks.example.com/lead

# Per-clinic Meta CAPI access token
# META_CAPI_TOKEN_PRAXIS_MUELLER_MUENCHEN=EAAB...

# HubSpot (only if LEAD_CRM_ADAPTER=hubspot)
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PORTAL_ID=

# Optional Slack alert when leads arrive (low-priority)
LEAD_ALERT_SLACK_WEBHOOK=

# ── Double-Opt-In (marketing consent) ──────────────────────────────────────
# Required for the marketing checkbox to actually send a confirmation e-mail.
# Without these set, the lead is still accepted but no DOI mail is sent and the
# CRM never sees a `marketing-confirmed` event.

# Resend API key (https://resend.com). Free tier is fine for low volume.
RESEND_API_KEY=

# From-address for the confirmation e-mail. Must be on a domain you've verified
# in Resend. Plain address (e.g. noreply@einsvisuals.de) or "Name <addr>" both work.
# We prepend the clinic name automatically if you pass a plain address.
DOI_FROM_EMAIL=

# HMAC secret used to sign DOI tokens. Generate with `openssl rand -hex 32`.
# Rotating this invalidates all outstanding confirmation links (by design).
DOI_SIGNING_SECRET=

# ── EINS Portal lead mirror ────────────────────────────────────────────────
# Every accepted lead is fan-out POSTed to the portal's /api/leads/intake
# route, HMAC-SHA256 signed with a per-clinic shared secret. Leave PORTAL_URL
# unset or per-clinic secrets unset to disable the mirror for that clinic —
# the lead still flows to the CRM / Meta CAPI / DOI mail unaffected.

# Base URL of the EINS portal (no trailing slash). For local dev:
# PORTAL_URL=http://localhost:3001
PORTAL_URL=

# Per-clinic shared HMAC secret. Variable name MUST match the
# `portalIntakeSecretEnv` field on the clinic config. Generate with
# `openssl rand -hex 32`; same plaintext goes into the portal's
# platform_credentials row (platform='intake') for this clinic.
# Example for the _template clinic:
# PORTAL_INTAKE_SECRET_TEMPLATE=
