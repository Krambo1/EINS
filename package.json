{
  "name": "eins-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:website": "pnpm --filter website dev",
    "dev:portal": "pnpm --filter portal dev",
    "dev:worker": "pnpm --filter portal worker",
    "build": "pnpm -r build",
    "build:website": "pnpm --filter website build",
    "build:portal": "pnpm --filter portal build",
    "start:website": "pnpm --filter website start",
    "start:portal": "pnpm --filter portal start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter portal test:e2e",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres redis",
    "db:migrate": "pnpm --filter portal db:migrate",
    "db:seed": "pnpm --filter portal db:seed",
    "db:studio": "pnpm --filter portal db:studio",
    "db:reset": "docker compose down -v && docker compose up -d postgres redis && sleep 3 && pnpm db:migrate && pnpm db:seed",
    "clean": "pnpm -r exec rm -rf .next dist .turbo && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.0",
      "@types/react-dom": "19.0.0"
    }
  }
}
